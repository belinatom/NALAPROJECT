        "# Tokenize all proverbs\n",
        "def tokenize(text):\n",
        "    return re.findall(r'\\b\\w+\\b', text.lower())\n",
        "\n",
        "# Swahili stopwords (common function words)\n",
        "swahili_stopwords = {\n",
        "    'na', 'ya', 'wa', 'la', 'za', 'kwa', 'ni', 'si', 'cha', 'vya',\n",
        "    'pa', 'ku', 'mwa', 'li', 'ki', 'vi', 'ji', 'mi', 'u', 'i', 'a',\n",
        "    'the', 'of', 'in', 'to', 'and', 'is'\n",
        "}\n",
        "\n",
        "all_tokens = []\n",
        "for proverb in df['swahili_proverb']:\n",
        "    tokens = tokenize(proverb)\n",
        "    all_tokens.extend([t for t in tokens if t not in swahili_stopwords and len(t) > 2])\n",
        "\n",
        "word_freq = Counter(all_tokens)\n",
        "top_words = word_freq.most_common(30)\n",
        "\n",
        "words, counts = zip(*top_words)\n",
        "\n",
        "# Bar chart\n",
        "fig, axes = plt.subplots(1, 2, figsize=(18, 7))\n",
        "\n",
        "# Top 30 words\n",
        "colors = plt.cm.Blues(np.linspace(0.4, 0.9, 30))[::-1]\n",
        "axes[0].barh(list(words)[::-1], list(counts)[::-1], color=colors)\n",
